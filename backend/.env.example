# Agentic AI Platform - Environment Configuration Template

# --- LLM Provider Settings ---
# Set to 'true' to use local LLMs (Ollama/LM Studio), 'false' for OpenRouter/OpenAI
USE_LOCAL_LLM=false
# Set to 'true' to use OpenRouter, 'false' to use official OpenAI API
USE_OPENROUTER_LLM=true

# --- API Keys ---
# Required if USE_OPENROUTER_LLM=true
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Required if USE_LOCAL_LLM=false and USE_OPENROUTER_LLM=false
# Also used as base key for some local setups
OPENAI_API_KEY=your_openai_api_key_here
# Required for web search capabilities
TAVILY_API_KEY=your_tavily_api_key_here

# --- LLM Configuration ---
# Base URL for the LLM API
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Name of the model to use (example: nvidia/nemotron-3-super-120b-a12b:free)
MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

# --- Infrastructure ---
# Redis URL for caching (example: rediss://default:password@endpoint.upstash.io:6379)
REDIS_URL=redis://localhost:6379
# Path for the ChromaDB vector database
VECTOR_DB_PATH=./chroma_db

# --- Security & Networking ---
# Comma-separated list of allowed origins for CORS (example: http://localhost:3000,https://your-app.vercel.app)
ALLOWED_ORIGINS=*
# Port to run the server on (defaults to 8000)
PORT=8000
